# AssoLink / Komunumo - Environment Variables
# Copy this file to .env and fill in the values.

# Server
KOMUNUMO_HTTP_ADDR=:8080
KOMUNUMO_SQLITE_DSN=./komunumo.db
KOMUNUMO_APP_BASE_URL=http://localhost:3000

# Brevo (transactional email)
# API key: https://app.brevo.com/settings/keys/api
KOMUNUMO_BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxxxxxxxxx
KOMUNUMO_BREVO_FROM_EMAIL=contact@yourdomain.fr
KOMUNUMO_BREVO_FROM_NAME=Komunumo
